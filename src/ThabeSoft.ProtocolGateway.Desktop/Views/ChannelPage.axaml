<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             
             xmlns:vm="using:ThabeSoft.ProtocolGateway.ViewModels"
             
             x:Class="ThabeSoft.ProtocolGateway.Views.ChannelPage"

             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:ChannelPageViewModel">

    <Grid RowDefinitions="Auto,*">

        <!--顶部信息-->
        <StackPanel Grid.Row="0" Orientation="Vertical">

            <!--信息-->
            <UniformGrid Height="50" Columns="2">

                <TextBlock VerticalAlignment="Center" Text="测试" />
                <TextBlock VerticalAlignment="Center" Text="测试" />

            </UniformGrid>

            <!--工具栏-->
            <DockPanel>

                <TextBox DockPanel.Dock="Left" Text="HelloWorld!" />
                <Button Margin="10 0" DockPanel.Dock="Left" Content="列"/>

            </DockPanel>

        </StackPanel>

        <DataGrid Margin="0 10 0 0" Grid.Row="1"
                  ItemsSource="{Binding ChannelItemsSource}"
                  AutoGenerateColumns="False"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True">

            <DataGrid.Columns>

                <DataGridTemplateColumn Header="名称" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <HyperlinkButton Content="{Binding Name}"
                                             Command="{Binding $parent[DataGrid].DataContext.OpenDetailsPageCommand}"
                                             CommandParameter="{Binding}"
                                             Classes="TextButton"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="协议" Binding="{Binding ProtocolType}" Width="*" />

                <DataGridTemplateColumn Header="操作" Width="Auto">

                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="🔗"
                                        Command="{Binding ConnectCommand}"
                                        Classes="DataGridButton"/>
                                <Button Content="🚮"
                                        Command="{Binding DisconnectCommand}"
                                        Classes="DataGridButton"/>
                                <Button Content="⏸"
                                        Command="{Binding PauseCommand}"
                                        ToolTip.Tip="启动"/>
                                <Button Content="▶"
                                        Command="{Binding ResumeCommand}"
                                        ToolTip.Tip="停止"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>

        </DataGrid>

    </Grid>

</UserControl>
