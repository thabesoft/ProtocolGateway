<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>

		<TargetFrameworks>net10.0</TargetFrameworks>
		<LangVersion>preview</LangVersion>
		<RootNamespace>ThabeSoft.ProtocolGateway</RootNamespace>
		<ImplicitUsings>enable</ImplicitUsings>
		<OutputType>WinExe</OutputType>
		<Nullable>enable</Nullable>
		<ApplicationManifest>app.manifest</ApplicationManifest>
		<AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
		<EnableConfigurationBindingGenerator>true</EnableConfigurationBindingGenerator>

		<IsAotCompatible>True</IsAotCompatible>
		<PublishTrimmed>True</PublishTrimmed>
	</PropertyGroup>

	<!--依赖包-->
	<ItemGroup>
		<PackageReference Include="Avalonia" Version="12.0.4" />
		<PackageReference Include="Avalonia.Controls.DataGrid" Version="12.0.0" />
		<PackageReference Include="Avalonia.Controls.ItemsRepeater" Version="12.0.0" />
		<PackageReference Include="Avalonia.Desktop" Version="12.0.4" />
		<PackageReference Include="Avalonia.Themes.Fluent" Version="12.0.4" />
		<PackageReference Include="Avalonia.Fonts.Inter" Version="12.0.4" />
		<PackageReference Include="AvaloniaUI.DiagnosticsSupport" Version="2.2.1">
			<IncludeAssets Condition="'$(Configuration)' != 'Debug'">None</IncludeAssets>
			<PrivateAssets Condition="'$(Configuration)' != 'Debug'">All</PrivateAssets>
		</PackageReference>
		<PackageReference Include="Xaml.Behaviors.Avalonia" Version="12.0.0.1" />
		<PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.8" />
	</ItemGroup>
	
	<!--依赖项目-->
	<ItemGroup>
	  <ProjectReference Include="..\ThabeSoft.Mvvm\ThabeSoft.Mvvm.csproj" />
	  <ProjectReference Include="..\ThabeSoft.ProtocolGateway.Runtime\ThabeSoft.ProtocolGateway.Runtime.csproj" />
	  <ProjectReference Include="..\ThabeSoft.ProtocolGateway.Configuration\ThabeSoft.ProtocolGateway.Configuration.csproj" />
	</ItemGroup>

	<!--配置文件-->
	<ItemGroup>
		<None Update="appsettings.json">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</None>
		<None Update="Configs\Default.json">
		  <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</None>
	</ItemGroup>

</Project>
